<?xml version="1.0" encoding="utf-8"?>
<!--
    2×2 Daily Spend Widget
    NOTE: RemoteViews does NOT support android:letterSpacing, custom drawables on View,
    or layout_weight inside a gravity="center" LinearLayout — all avoided here.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_spend_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <!-- Label -->
    <TextView
        android:id="@+id/spend_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/widget_label_today_spend"
        android:textColor="#8E8E8E"
        android:textSize="11sp"
        android:fontFamily="sans-serif-condensed"
        android:gravity="center"
        android:layout_marginBottom="6dp" />

    <!-- Large rupee amount — updated by provider -->
    <TextView
        android:id="@+id/spend_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/widget_amount_default"
        android:textColor="#FFFFFF"
        android:textSize="34sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-condensed"
        android:gravity="center"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="8dp" />

    <!-- Thin divider — implemented as a TextView background to avoid unsupported View attrs -->
    <TextView
        android:layout_width="132dp"
        android:layout_height="1dp"
        android:layout_gravity="center_horizontal"
        android:background="#383838"
        android:layout_marginBottom="8dp" />

    <!-- Date -->
    <TextView
        android:id="@+id/spend_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/waiting_for_sms"
        android:textColor="#737373"
        android:textSize="11sp"
        android:fontFamily="sans-serif-condensed"
        android:gravity="center" />

</LinearLayout>



